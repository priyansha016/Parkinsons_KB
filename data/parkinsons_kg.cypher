4020704, -0.06618049, 0.008340479, 0.012754747, 0.008169452, -0.01827097, -0.01270228, -0.02083185, 0.02022742, -0.020249357, -0.001668272, -0.03020102, 0.07480253, 0.0132391555, -0.015521064, -0.036599275, -0.012991514, 0.03347432, 0.05776713, -0.027421553, 0.063540705, 6.284318E-4, -8.646606E-4, -0.024037646, 0.023666382, 0.016885126, -0.025326494, 0.017134681, 0.062414374, -0.036063984, -0.012195024, 0.0242391, -0.06963319, 0.0057801637, -0.033443764, -0.029730426, -0.028333694, 0.0073607992, 0.008195745, 0.047344442, -0.019323245, 0.044054538, -0.011965334, 0.03909374, 8.70588E-4, -0.028251426, 0.029224757, 0.02194655, 0.014039404, -0.022968275, 0.0045567914, 0.0022764693, 0.05402138, 0.026134899, 0.02691393, 0.02447793, 0.009311141, 0.027569572, -9.238253E-4, -0.069088325, -0.010482042, 0.054540075, -0.0042859367, -0.037708428, -0.07726763, -0.0346332, 0.04998752, -0.006484677, 0.06404582, -0.047957096, -0.004427042, -0.015754184, -0.0062122787, -0.023407998, -0.0476238, -0.01794502, 0.011517228, 0.025158286, -0.051857095, 8.668766E-4, -0.09502788, -0.025598861, -0.050694197, 0.014480081, 0.012613189, 0.010030191, -0.044851, 4.249704E-4, -0.0013768139, 0.038953293, -0.0038072523, -0.0017773445, 0.0489078, -0.0023428653, -0.052976325, 0.054071855, 0.029228622, -0.023874203, -0.013905079, 0.025919408, 0.06667225, 0.00337034, 0.0036313403, -0.014780125, 0.046071284, -0.019475115, -0.04172587, -0.021232367, -0.016533647, -0.03158776], text:"After a short historical overview, we make the case that the aggre­\ngation of α-synuclein into Lewy pathology is a normal, protective reac­\ntion against a wide range of biological stressors as well as toxic or \ninfectious exposures and that the longer the aggregation process goes \non, the less of the normal protein remains. We review the evidence on \nwhich the gain-of-function toxic synucleinopathy hypothesis is based \nand propose an alternative loss-of-function synucleinopenia hypothesis. \n1.1. From neuroprotection to neurotoxicity \nIn several experiments in a rodent model of apoptosis in the 1990s, \nBurke and collaborators at Columbia University demonstrated that \nsynuclein aggregation was “likely to play a role in protection or resto­\nration of neurons destined to survive.” [4,5] These observations were \novershadowed by two others, published around the same time: that \n* Corresponding author. Department of Neurology, University of Cincinnati Academic Health Center, 260 Stetson St., Suite 2300, Cincinnati, OH, 45267-0525, \nUSA. \nE-mail addresses: alberto.espay@uc.edu, aespay@gmail.com (A.J. Espay).  \nContents lists available at ScienceDirect \nParkinsonism and Related Disorders \njournal homepage: www.elsevier.com/locate/parkreldis \nhttps://doi.org/10.1016/j.parkreldis.2024.106077 \nReceived 18 January 2024; Received in revised form 26 February 2024; Accepted 27 February 2024", page:1}}, {_id:2846, properties:{chunk_index:0, id:"1-s2.0-S1353802024000890-main.pdf::p2::0::519016e5", embedding:[0.064736575, 0.0663313, -0.15476696, -0.051604006, 0.004593111, -0.0040920973, 0.0014239708, 0.05231713, 0.045325093, -0.007406942, 0.00660478, 0.0069180746, 0.110563025, 0.0090405615, 0.002615044, -0.080473945, 0.0017187337, -0.021249518, -0.044922255, 0.03304953, -0.04539266, -0.008397711, 0.02695627, -0.018522887, 0.06245646, 0.07764309, -0.05318241, -0.04628909, 0.05159223, 0.021054102, 0.12525646, 0.006964686, 0.017052162, -2.2351544E-4, -0.04595569, -0.05271947, 0.035045277, 0.024170902, 0.030117763, 0.015282094, -0.018707488, 9.006718E-4, -0.010811909, -0.07698734, -0.014836429, 0.04591586, 0.03340017, -0.009295093, 0.059280474, -0.062372394, 0.011098739, 0.0046878727, 0.012567185, -0.037859164, 0.08511981, 0.04900202, 4.797291E-4, -0.03087981, 0.0017456702, -0.012712128, 0.05052457, 0.065523826, -0.039085098, -0.0066733323, 0.014083566, -0.046272434, -0.01136379, 0.056909245, -0.009930318, -0.061130892, 0.05846199, -0.015106119, -0.008887222, 0.024036145, -0.011519173, 0.0077
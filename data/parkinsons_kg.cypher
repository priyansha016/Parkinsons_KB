 -0.033635948, -0.040190645, 0.015536262, 0.05794072, 0.041814405, 0.04505863, -0.05698692, 0.021848325, -0.012846062, 0.03771629, -0.011102727, -0.034285296, 0.005866476, 0.036137357, -0.015452825, -0.021008523, 0.036076065, -0.006868387, -0.019088924, 0.024218122, -0.011201964, 0.032946862, -0.0031322485, 0.022758814, 0.047489043, -0.021594584, 0.059171963, -0.00744348, 0.032058857, 0.025564691, 0.012136985, -0.027902583, 0.020384684, -0.029743593, -3.922707E-4, -0.026849799, 0.0020986765, 0.014410097, 0.0591771, -0.009753533, 0.046768345, -0.014494116, 0.03476521, -0.0046610413, -0.035518736, 2.0502704E-4, 0.06102747, 0.03480119, -0.00834499, -0.08115592, 4.3247643E-4, 0.010620117, 8.7506487E-4, 0.0893346, -0.0031398018, 0.019105105, 0.0066336766, -0.033281717, -0.014916573, -0.04744843, 0.0122405235, 0.021739058, 0.017397111, -0.033755135, -0.04842068, -0.120588765, 0.0021869808, -0.025274662, -0.023880547, 0.014206231, 0.0352629, -0.02657596, -0.026373161, -0.031995803, 0.052746706, 0.067991324, -0.017797118, 0.013443014, -0.03343821, -0.0014349055, 0.036818996, 0.019768542, -0.02083129, 0.012143773, 0.018563561, 0.032153953, -0.016292924, 0.058056388, -0.025086276, 0.037891835, 0.025551826, -0.04472351, -0.011137121, -0.02345022, -0.018904883], text:"element RNA-binding protein 1 (AUF1) binding to LRRK2 mRNA. AUF1 binds to the AU-rich element of LRRK2 which\nresponds to AICAR and promotes the decapping enzyme complex DCP1/2 to decap LRRK2 mRNA, leading to LRRK2\nmRNA decay, and ﬁnally reducing the LRRK2 protein level. AICAR-mediated LRRK2 protein reduction signiﬁcantly\nrescues LRRK2-mediated neuronal toxicity and neuroinﬂammation in animal models. AICAr must be internalized into cells\nby adenosine transporter (AT) and converted to AICAR/ZMP by adenosine kinase (ADK) to exert its effects on LRRK2,\nwhich is independent of AMPK. AICAR/ZMP itself is not membrane permeable.\nTrends in Molecular Medicine\nTrends in Molecular Medicine, October 2024, Vol. 30, No. 10\n991\nregarding long-term treatment side ef-\nfects as a result of decreased LRRK2\nactivity in the immune system.", page:10}}, {_id:2546, properties:{chunk_index:0, id:"PIIS1471491424001898.pdf::p11::0::af8b269f", embedding:[0.0013903207, 0.08465591, -0.120016165, -0.036738113, 0.039347753, -0.035197824, 0.004694301, 0.043059085, 0.0047912956, -0.066291146, 0.0013234421, 0.05228645, 0.11301746, -0.014036525, 0.040926535, -0.0017556386, -0.020221414, -0.034427073, -0.0012323502, 0.050621122, -0.07475358, -0.0048783426, 0.036798768, -0.040578663, 0.02639111, 0.072069205, 0.03354437, -0.035005037, -0.003050887, 0.04585374, 0.058310073, -0.037216183, -0.027798798, -0.020288046, -0.029027322, -0.07053314, 0.1168017, 0.030727068, -0.031242363, 0.015755175, -0.005203015, 0.027819432, 0.005869753, -0.053186476, 0.04262442, 0.03003212, 0.013942785, 0.0090872925, 0.09496137, -0.09268176, 0.0676494, -0.014105211, -0.0050170016, -0.064609945, 0.123651765, 0.019707674, -0.007464034, -0.01157157, 0.034652002, 0.005571449, 0.072762474, 0.04724273, -0.074112885, 0.025308719, 0.056901157, -0.07694883, -0.0153194275, 0.025088243, 0.03779092, -0.013497621, 0.05192575, -0.016976926, 7.052776E-4, 0.0036234257, -0.025732275, -0.0049733613, 0.021602128, -0.009572833, -0.020241847, 0.010781317, -0.02321251, -0.013254002, 0.030953106, 0.029416565, 0.01625132, -0.0016965282, -0.043188315, -0.0043689194, -0.029322302, 0.06592348, -0.014078171, 0.02013138, -0.004111886, -9.2710304E-4, -0.030427504, 0.035010688, 0.07089304, 0.011088279, -0.029546862, 0.00618913, -0.028273486, 0.032330297, 0.018398926, 0.006873155, 0.00689156, 0.03384732, 0.049112234, -0.00749654, 0.033675935, 0.028669985, -0.047841605, 0.046331342, -0.03787795, -0.040268503, 0.010779895, 0.006503021, 0.03425756, -0.015674112, 0.007836579, 0.052877367, -0.034252875, -0.028817069, -0.0059285657, 0.06764448, 0.005993854, 0.022469245, -0.0807123, -0.0039539756, 0.0010054997, -0.05263222, -0.013116221, -0.04574617, -0.06222608, -
, 0.0152263995, -0.0018272195, 0.053136434, -0.0073830555, -0.050779294, 0.012929971, 0.013663954, 0.015970282, -0.0045109605, 6.8229565E-4, 0.011379535, 0.011721165, 0.035703845, 0.0267045, -0.027467983, 0.055183776, -0.021160657, 0.019599592, 0.02464642, -0.003675074, 0.01333778, 0.013885239, 0.0145895, 0.0058336677, 0.018864704, 0.003590437, 0.026768757, 0.059545197, 0.0071860743, 0.041283395, 0.0054794317, 0.061686143, -0.0126050105, -0.04493652, -0.008853218, 0.06388013, 0.026281452, -0.0071695363, -0.073645756, 0.0065187863, 0.0202113, 0.0035612038, 0.09090032, -0.027161926, 0.016245503, -0.026914187, -0.05349506, -0.01989663, -0.047446825, 0.02305378, 0.0081168935, 0.03413153, -0.026243024, -0.028629012, -0.04923851, -0.05358421, -0.018861415, -0.011271754, -0.005540483, 0.026502138, -0.04258823, 0.03150495, -0.022753134, 0.03030016, 0.061196975, -1.6165455E-4, 0.0021133865, 0.01269026, -0.009321679, 0.032910723, 0.00812578, -0.0466572, -0.035014972, 0.022633608, 0.06886666, -0.024401616, 0.020359281, -0.014590994, 0.031712003, 0.0026284838, -0.014523865, 0.014600968, -0.033125356, -0.029754885], text:"tant proteins have distinct subcellular localizations which may affect their proximity to Rab10.\nLRRK2 phosphorylates membrane- and GTP-bound Rab proteins within their Switch II domain, where the Rab effectors bind,\nthereby blocking normal Rab GTPase function and retaining Rab proteins at the membranes, thus preventing normal\nendolysosomal trafﬁcking [5]. Phosphorylation of Rab8 and Rab10 by LRRK2 enables them to bind to a subset of new effec-\ntors, including RILPL1/2, JIP3/4, EHBP1/L1, and CHMP4B, causing the recruitment of LRRK2 with Rab8 and Rab10 to the\ndamaged lysosomes [91,142–145]. These scenarios occur upon lysosomal stress. Whether the different phosphor-Rab/new\neffector complexes exist under normal conditions and in vivo in the brain, and how these phenomena are disease-relevant,\nremain unknown. It is also unclear whether and how LRRK2 phosphorylates different Rab proteins on distinct membranes.\nTaken together, these raise the possibility that LRRK2 acts as a regulatory kinase in endolysosomal trafﬁcking at synapses\nand different cell types.\nTrends in Molecular Medicine\n988\nTrends in Molecular Medicine, October 2024, Vol. 30, No. 10", page:7}}, {_id:2534, properties:{chunk_index:0, id:"PIIS1471491424001898.pdf::p8::0::a5e96931", embedding:[0.037552197, 0.099044815, -0.1329608, -0.023757797, 0.053794567, -0.031045407, 0.008406488, 0.012227812, 0.015504667, -0.065002955, -0.0194342, 0.040764857, 0.09553422, 0.021028494, 0.030731695, -0.03526832, -0.0028392216, 0.007569552, -0.019049147, 0.053309858, -0.06748307, 0.0028577815, 0.012290328, -0.02778993, 0.08128731, 0.1463892, 0.018249143, -0.045065865, 0.005858578, 0.009136315, 0.08960967, -0.050797306, -0.02211191, -0.033016913, -0.025989428, -0.045740917, 0.07969565, 0.049138643, 0.00996681, 0.013224791, -0.029659515, -0.0016105928, 0.0035205511, -0.0628636, 0.008271686, 0.033396903, 0.032793425, -0.055494234, 0.032206684, -0.046151202, 0.0513926, 0.029555691, -0.005112995, -0.042418808, 0.11847483, -0.0282749, 0.034115113, -0.04806778, 0.04492613, 0.02628834, 0.07440144, 0.09725056, -0.06031808, 0.035139248, 0.016357962, -0.051139247, 0.0039058486, 0.031152295, -0.03718973, -0.019394077, 0.07068319, -0.043417986, 0.004473555, 0.036164366, -0.035277843, -0.020879475, 0.05692678, 0.03509548, 0.0026642864, 0.013881319, -0.0066392324, 0.013399018, 0.05633982, 0.0114389, 0.02206448, 0.04178636, -0.066467665, -0.07527646, -0.014044581, 0.05630848, 0.023268305, 0.022756862, 0.007723898, 9.6982694E-4, -0.043914244, 0.017747367, 0.0324993, 0.011065324, -0.05300328, -0.018258646, 0.0058021154, -0.034311906, 0.016596802, -0.005867433, 0.03897967, 0.04483075, 0.025764337, -0.013129746, 0.032208096, 0.021649258, -0.0614287, 0.06382111, -0.011087564, -0.009263985, 0.02646273, -0.035256892, 0.052795153, -0.01820949, -0.024656856, 0.053270303, -0.03579893, -0.0168561
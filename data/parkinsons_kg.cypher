8425225, -0.03554193, -0.02685751, -0.046209868, 0.020188857, 0.024599105, 0.03574366, 0.021188512, -0.031167634, 0.06939843, -0.025212599, 0.0047477107, -0.0056765536, 0.0036548984, -0.0132055, 0.027898023, 0.026912201, 0.0046783946, -0.009571534, -0.028829128, -0.04289046, 0.029217672, -0.016638234, 0.04916213, -0.00107736, 0.0671009, -0.011023313, -0.025879752, 0.0032069741, 0.0740915, 0.043456443, -0.029084187, -0.0844464, -0.00569997, 0.004099465, 0.014694593, 0.074687086, -0.0062229396, -0.0065074083, -0.0038587272, -0.012274924, -0.014005418, -0.043778103, -0.030492699, -0.0345519, 0.0014910524, -0.012976861, 0.007738308, -0.052612897, -0.029576609, -0.04193664, -0.0031473543, -0.002087722, 0.031891137, 0.016747449, 0.026826847, -0.014951384, 0.03840336, 0.04275295, 0.024096604, -0.01597424, 0.059711125, -2.4645837E-4, 0.015323969, -0.013330078, -0.0021176015, -0.022730509, 0.05339548, 0.04055421, -0.029323623, 0.059981078, -0.02338956, 0.041144427, -0.016910218, -0.04230864, -0.0017182385, -0.038311627, -0.039984122], text:"tion and membrane recruitment appear\nto be required for LRRK2 activation.\nRab29/12/38/32/8/10 and VPS35 are\nemerging upstream activators of LRRK2.\nA unique feature of LRRK2 is that it pos-\nsesses two enzymatic functions: kinase\nand GTPase. It phosphorylates a group\nof proteins including Rabs and its auto-\nphosphorylation site S1292. LRRK2\nGTPase regulation and contribution to\nPD is understudied.\nLRRK2 plays a diverse role in multiple\ncellular pathways.\nLRRK2 could be targeted on enzymatic\nactivities, protein levels, crucial cellular\ninteractors, and dimerization. Targeting\nLRRK2 kinase activity and protein levels\nhas shown promise, and some ap-\nproaches are advancing to clinical trials.\n1Department of Neuroscience, University\nof Connecticut School of Medicine,\nFarmington, CT 06030, USA\n2Department of Physiology and\nNeurobiology, University of Connecticut,\nStorrs, CT 06269, USA\n*Correspondence:\nyxiong@uchc.edu (Y. Xiong).\n982\nTrends in Molecular Medicine, October 2024, Vol. 30, No. 10\nhttps://doi.org/10.1016/j.molmed.2024.07.003\n© 2024 Elsevier Ltd. All rights are reserved, including those for text and data mining, AI training, and similar technologies.\nTrends in\nMolecular Medicine", page:1}}, {_id:2513, properties:{chunk_index:0, id:"PIIS1471491424001898.pdf::p2::0::5c14daa6", embedding:[0.017034642, 0.057472628, -0.15623254, 0.0073694135, 0.059891917, -0.01753537, 0.0054274052, 0.057964925, -0.0067271115, -0.056485057, -0.04797442, 0.06555986, 0.09416813, 0.023721987, 0.009002989, -0.029535662, -0.019978521, 0.020648845, 0.020245053, 0.09189176, -0.071842216, 0.0052141612, 0.017901126, -0.03812541, 0.06612739, 0.042261124, 0.011996165, -0.0010078573, -0.033719517, 0.025947085, 0.064252205, -0.047901057, -0.019532578, -0.02340899, -0.028252896, -0.06024365, 0.10666501, -0.0035791553, 0.004119042, 0.021229535, 0.022671266, 0.041670002, -0.018716417, -0.032276064, -0.00917548, 0.021707926, 0.0049319454, 0.013658793, 0.038236097, -0.09387131, 0.07089541, -0.008623719, 0.032625068, -0.04063824, 0.10987994, 0.034928836, -0.03166307, 0.053535998, 0.021837728, -0.009098288, 0.069630496, 0.0446089, -0.070341565, -0.0012337326, 0.05978474, -0.054058768, -0.01120242, 0.03846968, -0.010520593, -0.037807938, 0.050383262, -3.4520525E-4, -0.005076597, 0.04249146, -0.0031226662, 0.03688338, 0.0047412864, 0.01828293, -0.013237271, 0.013500116, -0.0020632516, -0.0074061835, 0.038912486, 0.0110042235, 0.018903947, -0.0010848107, -0.02162076, 0.02238677, -0.02635833, 0.050795484, 4.269932E-4, 0.030498441, 0.03500769, 0.024797413, -0.048099354, 0.020298975, 0.045867845, 0.026849406, -0.020419305, 0.013872147, 0.014642898, 0.009909404, 0.030877259, 0.019873051, -0.039786752, 0.01266934, 0.043109912, -0.019880293, 5.5980796E-5, 0.035632595, -0.034148086, 0.036903463, -0.034949757, -0.010186576, 0.022084545, -0.014571534, 0.031216722, -0.016887618, -0.010629754, 0.00821129, -0.0530504, -0.0
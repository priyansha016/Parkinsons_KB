ed to rare,\nfamilial forms of PSP or PSP-like conditions\nGenetics of Parkinson’s Disease\nCite this article as Cold Spring Harb Perspect Med 2025;15:a041774\n11\nwww.perspectivesinmedicine.org\nPress \n on November 10, 2025 - Published by Cold Spring Harbor Laboratory\nhttp://perspectivesinmedicine.cshlp.org/\nDownloaded from", page:11}}, {_id:2935, properties:{chunk_index:0, id:"Cold Spring Harb Perspect Med-2025-Westenberger-a041774.pdf::p12::0::f99f1bc6", embedding:[0.07738987, 0.082961656, -0.14644735, 0.0073743835, 0.04961706, 0.030701984, 0.012182283, -0.02266157, 0.012519396, -0.04658247, 0.016928803, 0.036886267, 0.0805764, 0.0029553152, 0.014006956, -0.02030541, 0.022972712, -0.020464377, 0.020374678, 0.025932306, -0.0635345, -0.0033099072, -0.022072015, -0.029384397, 0.07263674, 0.05172238, -0.056446664, -0.0116650555, -0.005643998, 0.0044962633, 0.10117903, -0.010780493, 0.019353453, -0.038524624, -0.011566311, -0.07009849, 0.0791517, 0.015657557, 0.04024978, 0.015096848, 0.014042648, 0.032096744, 0.013535382, -0.04944411, 0.026868736, 0.029989868, 0.038047135, -0.0034248307, 0.109987766, -0.013848522, 0.051043443, -0.008545762, 0.057758536, -0.04906092, 0.08143448, 0.035025045, 0.003470384, 0.0043017184, -0.013371953, -0.027404513, 0.07760683, 0.06889029, -0.07684304, 0.014424417, 0.039948713, -0.0409487, 0.0075352867, 0.026175143, 0.024345357, -0.052307043, 0.0269223, -0.0051248255, 0.019784806, 0.020715382, -1.8977021E-6, 0.009426549, 0.028298894, 0.0138568, -0.012797455, 0.041883722, -0.029405056, 0.025379144, 0.022603152, 0.03753876, 0.03231548, 0.020536872, -0.028398296, 0.004667385, 0.0082411645, 0.07969149, 0.05183665, -0.003665539, 0.026547827, -0.005505862, -0.032738615, 0.022945227, 0.021970462, 0.03376498, -0.054935865, 0.021617413, -0.021673802, 0.009863773, -0.01696267, -0.016809972, -0.0015660588, 0.03482218, 0.05620574, -0.028722364, -0.03255838, 0.019589897, -0.010385119, 0.041720916, -0.0108857835, -0.022990642, -0.014577644, -0.005736
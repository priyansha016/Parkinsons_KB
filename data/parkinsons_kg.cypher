ess \n on November 10, 2025 - Published by Cold Spring Harbor Laboratory\nhttp://perspectivesinmedicine.cshlp.org/\nDownloaded from", page:4}}, {_id:2906, properties:{chunk_index:0, id:"Cold Spring Harb Perspect Med-2025-Westenberger-a041774.pdf::p5::0::57f82fdf", embedding:[0.0530056, 0.058868762, -0.1485217, 0.0010716738, 0.031947352, -0.005672099, 0.02528915, -0.0028456151, 0.0570972, -0.0014258265, -0.020556664, -0.026012706, 0.093670204, 0.031618733, -0.023754487, -0.044666495, -0.035178762, -0.01786456, 0.009763126, 0.0588612, -0.09498833, 0.0015016171, 0.038674753, -0.055224363, 0.07452371, 0.09839671, -0.044921357, -0.013807249, -0.004053494, -0.018058771, 0.11593316, -0.016264802, 0.023304632, -0.03984267, -0.063162066, -0.03929847, 0.07173627, 0.021852585, 0.051751036, 0.070520796, 0.027022203, 0.035803903, 0.016838381, -0.050321493, 9.823386E-4, 0.037337046, 0.05060935, 0.010428319, 0.06908959, -0.07939001, 0.03815385, -0.025626443, 0.031173678, -0.023671964, 0.08207408, 0.035358008, -0.045764674, -0.006887386, -0.0032818995, -0.023048524, 0.072040856, 0.0503955, -0.043805465, 0.022372723, 0.032353822, -0.018162573, -0.03118637, 0.05230626, 0.03190725, -0.055761606, 0.048030827, 0.0066319047, 0.005162135, 0.03823587, -0.009594247, -0.0037298112, 0.031667132, -0.010447491, 0.00441511, 0.01818913, 0.022526728, -0.023016848, 0.04286261, 0.015721902, 0.03651204, 0.00927051, 0.013009239, 0.025141882, -0.028475303, 0.0565986, 0.048936367, -0.010805892, 0.0025484005, -1.956669E-4, -0.06268298, 0.0027004045, 0.017856106, 0.028757608, -0.057894416, 0.011271977, -0.018291453, -0.012923473, -0.0017468102, 0.014933794, -0.031615365, 0.047913577, 0.01644014, -0.017061265, -0.0146434605, -0.0035304264, -0.04928828, 0.022473412, 0.019340597, -0.0069402787, -0.014304031, -0.019016886, -0.010831607, -0.0022803554, 0.022639167, 0.059093375, -0.0561815, -0.053920552, -0.04397461, 0.08528857, -0.019263707, 0.01453995, -0.038876034, -0.0325381, 0.063482255, -0.051612783, -0.0
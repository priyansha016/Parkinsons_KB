7925, 0.028355882, -0.0033413782, 0.0012518552, 0.044601306, 0.03860841, -0.054558527, -0.06852585, -0.06376594, -0.027517047, 0.007351641, -0.022621488, 0.0012742733, 0.024238097, -0.03333332, -0.0138340965, -0.03196451, -0.032910243, -0.024883274, 0.06161127, -0.007215468, -0.029106477, -0.0133991735, -0.016689308, 0.0053886073, 0.051123507, 0.0744342, 0.017158786, -0.010990012, -0.0072125234, 0.011869341, 0.01545108, 0.014443288, -0.016038405, -0.025683427, -0.009925345, -0.04700571, -0.056681238, -0.002721726, -0.03498324, -0.03898552, 0.0019969908, -0.025176905, -0.007188318, 0.009387636, 0.029958079, 7.593864E-4, 0.002787042, 0.06296821, -0.016300142, -0.0017269484, -6.6071644E-4, 0.007239631, 0.010500254, -0.008942659, 0.030725265, 0.00826049, 0.009006401, -0.033970423, -0.026901579, 0.05293022, 0.020363025, 0.050175514, -0.002756012, 0.04750053, -0.037549883, -0.06678885, -0.012111696, 0.020475885, 6.189637E-4, -0.015932968, -0.11929826, -0.028980842, -0.0034907882, -0.026327968, 0.028114378, -0.039943226, 0.033704713, -0.008404199, 0.01949636, 4.0958528E-4, -0.024373185, -0.028912531, -0.024840754, 0.018471818, -0.013403178, -0.022558257, -0.054595795, -0.035231017, -0.026016125, 0.03117456, -0.010137907, 0.008466398, 0.005505988, 0.016244682, -0.013010765, 0.052570697, 0.019281352, -0.015851093, 0.019150726, 0.0129645, -0.04928049, 0.058103275, -0.022140488, -0.012271582, 0.035605025, 0.036472622, 0.1216698, 0.0012286368, 0.059551377, -0.03194379, 0.046848714, 0.008553947, -0.045264076, -0.018874837, -0.032618087, -0.027542835], text:"assays still need to be developed.\nThe development of a ligand suitable\nas an LRRK2 positron emission to-\nmography (PET) tracer has not been\nvery successful.\nLRRK2\nmutations\nare\nstill\nrare,\nalthough they are the most common\ncauses of PD. Carriers of LRRK2\nmutations may\nprogress\nslower.\nThus, a larger and longer trial might\nbe required, which poses challenges\nfor LRRK2 trial design and recruitment.\nPrecisely targeting patients with LRRK2\nmutations for different clinical trials is\nanother challenge.\nLRRK2 mutations are found not only in\nPD but also in immune-related disor-\nders such as inﬂammatory bowel dis-\nease and leprosy. This suggests an\nimportant role of LRRK2 in the periph-\nery and inﬂammation. In primates, inhi-\nbition of LRRK2 produced reversible\nlamellar bodies in the lungs, despite\nno clinical manifestations in the short\nterm. Given that LRRK2 therapy will\nbe chronic, caution must be taken", page:9}}, {_id:2544, properties:{chunk_index:0, id:"PIIS1471491424001898.pdf::p10::0::02c67732", embedding:[-0.024640853, 0.04364948, -0.12856741, 0.02255876, 0.051093597, -0.053005345, 0.038215525, 0.070136845, 0.0022482178, -0.063342124, -0.021646542, 0.057660993, 0.087451614, -0.009806285, 0.025072133, -0.0419616, 0.004947857, -0.016852966, 0.004697806, 0.080639005, -0.07172738, 0.01685275, 0.03149134, -0.037968457, 0.033389766, 0.0556611, 0.016877491, -0.04641802, 7.2537566E-4, 0.037995808, 0.059553053, -0.069315635, -0.039856326, -0.029080855, -0.03729793, -0.044187408, 0.10427301, 0.03232308, 0.0032125458, -0.036448885, -0.006883441, 0.020745577, 0.023109658, -0.046226848, 0.004313157, -0.011332793, 0.0061452677, 0.002426406, 0.031657718, -0.06921684, 0.0935586, 0.018833157, 0.011717723, -0.05378659, 0.117472574, 0.0335316, -0.048199654, 0.012614163, 0.03657826, -0.015849706, 0.05984501, 0.06102651, -0.05162069, 0.0034728008, 0.070133075, -0.08254049, -0.024836266, 0.05288274, -0.0041506332, -0.036343653, 0.057844076, -0.022237776, -0.0026108061, 0.013548806, -0.014118039, -0.0010895362, 0.03159715, -0.006377273, 0.014727055, -9.1774284E-4, -0.02233174, -0.0061904374, 0.08093122, 0.012842097, 0.027169557, 0.033140145, -0.06282602, 0.014550137, -0.031571385, 0.06264468, -0.021035029, 0.024377706, 0.017423712, 0.03601017, -0.07642415, 0.017333595, 0.036289025, 0.0101922555, -0.019907776, 0.043126546, 0.0039347736, 0.005759066, 0.032034807, 0.0212269, -0.00
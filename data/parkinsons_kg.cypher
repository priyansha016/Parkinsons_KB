Harbor Laboratory\nhttp://perspectivesinmedicine.cshlp.org/\nDownloaded from", page:2}}, {_id:2900, properties:{chunk_index:0, id:"Cold Spring Harb Perspect Med-2025-Westenberger-a041774.pdf::p3::0::12ecb568", embedding:[0.030615166, 0.06934385, -0.16701321, -0.013638494, 0.027413458, 0.0053080237, 0.0033316994, 0.029029379, 0.014682082, -0.027120484, -0.021015843, 0.034477558, 0.10917841, 0.010008479, -0.021408482, -0.040784046, -0.0476861, 1.9641219E-4, -0.010277763, 0.040731113, -0.029900484, -0.036400508, -0.011550005, -5.630053E-4, 0.07184867, 0.02684388, -0.009479403, 0.0067547737, -0.0078020934, -0.013234579, 0.04098174, 7.6389266E-4, 0.005185326, -0.009915813, -0.025670901, -0.0048495047, 0.0397586, -0.04878648, 0.04550967, 0.05513289, 0.06736807, 0.006819634, -0.02177138, -0.06517117, 0.009621421, 0.05371032, 0.078774646, 0.03234876, 0.07544672, -0.10391467, 0.03568302, 0.04736323, 0.0609368, -0.011656788, 0.08375186, -0.013778833, -0.05368756, 0.01832303, -0.012546816, -0.07455951, 0.053818215, 0.0535047, -0.09059253, 0.020686768, 0.055259556, -0.057512477, -0.016587071, 0.017161876, 0.046854593, -0.0635279, 0.06270762, 0.029109927, 0.028702924, 0.060537677, 0.0019041884, -0.021403534, 0.04012617, -0.016894517, -0.0034690823, 0.013225831, 0.045498505, 0.0023115915, 0.047299646, 0.0053220927, 0.05219326, -0.028091313, -0.011370104, 0.0082600685, -0.021654826, 0.073285654, 0.046239402, 0.0050883386, 0.026917815, 0.002151957, -0.05499038, 0.040058576, -0.006395677, 0.042560015, -0.033741977, 0.015700284, -0.02950852, -0.02196858, 0.019744102, 0.03740762, -0.038706023, 0.033273738, 0.030680668, 0.012744261, -0.013183963, 0.03032199, -0.06464595, 0.03339286, -0.012156291, 0.0021083697, -0.01580685, -0.04184453, 0.026335401, -7.151477E-4, 0.023481684, 0.007877304, -0.028080234, -0.018750783, -0.04541594, 0.07926542, -0.02316808, -0.0015490251, -0.047613896, -0.014820943, 0.031287674, -0.021589642, -0.024483014, -0.029688997, -0.005642703, 0.026155308, -9.5343526